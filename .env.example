# football-data.org API key (free tier: https://www.football-data.org/client/register)
FOOTBALL_DATA_API=your_api_key_here

# DeepSeek API (for generating DeepSeek forecast)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Telegram bot credentials (from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_or_username_here
